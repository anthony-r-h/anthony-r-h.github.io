---
layout: null
---
[
{% assign searchable_posts_source = site.posts | where_exp:"post","post.is_generated != true" %}
{% assign searchable_posts = '' | split: '' %}
{% for post in searchable_posts_source %}
  {% assign hidden_hit = false %}
  {% for post_tag in post.tags %}
    {% if post_tag == "Hidden" %}
      {% assign hidden_hit = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% unless hidden_hit %}
    {% assign searchable_posts = searchable_posts | push: post %}
  {% endunless %}
{% endfor %}
{% for post in searchable_posts %}
  {
    "title": {{ post.title | jsonify }},
    "description": {{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},
    "tags": {{ post.tags | join: ' ' | jsonify }},
    "categories": {{ post.categories | join: ' ' | jsonify }},
    "date": {{ post.date | date: "%B %-d, %Y" | jsonify }},
    "url": {{ post.url | prepend: site.baseurl | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
