---
layout: null
---
[
{% assign searchable_posts = site.posts | where_exp:"post","post.is_generated != true" %}
{% for post in searchable_posts %}
  {
    "title": {{ post.title | jsonify }},
    "description": {{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},
    "tags": {{ post.tags | join: ' ' | jsonify }},
    "categories": {{ post.categories | join: ' ' | jsonify }},
    "date": {{ post.date | date: "%B %-d, %Y" | jsonify }},
    "url": {{ post.url | prepend: site.baseurl | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
